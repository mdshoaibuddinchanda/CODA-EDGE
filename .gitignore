# =============================================================================
# CODA — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Data — never commit raw, processed, or calibration data
# -----------------------------------------------------------------------------
data/raw/
data/processed/
data/calibration/
data/splits/

# Keep the directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/calibration/.gitkeep
!data/splits/.gitkeep

# -----------------------------------------------------------------------------
# Models — HuggingFace cached weights are large binary files
# -----------------------------------------------------------------------------
models/
!models/phi3-4bit/.gitkeep

# -----------------------------------------------------------------------------
# Outputs — results, plots, logs, covariance matrices are generated artifacts
# -----------------------------------------------------------------------------
outputs/covariance/
outputs/results/
outputs/plots/
outputs/logs/

# Keep directory stubs
!outputs/covariance/.gitkeep
!outputs/results/.gitkeep
!outputs/plots/.gitkeep
!outputs/logs/.gitkeep

# -----------------------------------------------------------------------------
# Python cache
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# -----------------------------------------------------------------------------
# Jupyter notebooks checkpoints
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# HuggingFace / datasets cache
# -----------------------------------------------------------------------------
.cache/
~/.cache/huggingface/
huggingface_cache/
hf_cache/

# -----------------------------------------------------------------------------
# NumPy / binary artifacts that are generated at runtime
# -----------------------------------------------------------------------------
*.npy
*.npz
*.pkl
*.pickle
*.pt
*.pth
*.bin
*.safetensors

# -----------------------------------------------------------------------------
# Logs and experiment artifacts
# -----------------------------------------------------------------------------
*.log
*.log.*
logs/

# -----------------------------------------------------------------------------
# OS / editor noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/settings.json
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Secrets and credentials — never commit these
# -----------------------------------------------------------------------------
.env
.env.*
secrets.yaml
secrets.json
credentials.json
*.pem
*.key

# -----------------------------------------------------------------------------
# Build / dist artifacts
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
site/

# -----------------------------------------------------------------------------
# PROGRESS.md — local tracking file, not needed in remote
# -----------------------------------------------------------------------------
PROGRESS.md
